{
  "name": "gtm-assistant",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "main": "dist-main/index.mjs",
  "scripts": {
    "dev": "vite --config vite.config.ts",
    "build": "tsc && vite build --config vite.config.ts",
    "electron:dev": "vite --config vite.config.ts",
    "electron:build": "tsc && vite build --config vite.config.ts && electron-builder",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "electron-store": "^10.0.0",
    "framer-motion": "^11.2.10",
    "lucide-react": "^0.395.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.3.0",
    "uuid": "^10.0.0"
  },
  "build": {
    "appId": "com.gtm-assistant",
    "productName": "GTM GA Assistant",
    "icon": "public/icons/icon",
    "win": {
      "icon": "public/icons/icon.ico"
    },
    "mac": {
      "icon": "public/icons/icon.icns"
    },
    "linux": {
      "icon": "public/icons/icon.png"
    }
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "electron": "^34.3.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.38",
    "typescript": "^5.2.2",
    "vite": "^5.3.1",
    "vite-plugin-css-injected-by-js": "^3.5.1",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}
